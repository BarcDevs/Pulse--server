{
  "info": {
    "name": "HealEase - Recovery Goals",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "apiVersion",
      "value": "v1",
      "type": "string"
    },
    {
      "key": "testEmail",
      "value": "",
      "type": "string"
    },
    {
      "key": "testPassword",
      "value": "",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "_csrf",
      "value": "",
      "type": "string"
    },
    {
      "key": "goalId",
      "value": "",
      "type": "string"
    },
    {
      "key": "milestoneId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth Errors",
      "item": [
        {
          "name": "Get Recovery Goals Without Authentication",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('testEmail', 'user@test.com');",
                  "pm.environment.set('testPassword', 'testpass123');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 401\", () => {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/recovery-goals",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "recovery-goals"]
            }
          }
        }
      ]
    },
    {
      "name": "Login",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json().data;",
                  "pm.environment.set('token', data.token);",
                  "pm.environment.set('_csrf', data._csrf);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"password\": \"{{testPassword}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "Create Goal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json().data;",
                  "pm.environment.set('goalId', data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "accessToken={{token}}"
              },
              {
                "key": "x-csrf-token",
                "value": "{{_csrf}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Test Goal\", \"description\": \"Test\", \"category\": \"health\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/recovery-goals",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "recovery-goals"]
