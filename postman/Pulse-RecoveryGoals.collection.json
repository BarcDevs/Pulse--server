              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200))",
                  "pm.test('Response has goals stats', () => {",
                  "    const data = pm.response.json().data",
                  "    pm.expect(data).to.have.property('goals')",
                  "    pm.expect(data.goals).to.have.property('totalCreated')",
                  "    pm.expect(data.goals).to.have.property('completed')",
                  "    pm.expect(data.goals).to.have.property('completionRate')",
                  "    pm.expect(data.goals).to.have.property('streak')",
                  "    pm.expect(data.goals).to.have.property('active')",
                  "    pm.expect(data.goals).to.have.property('paused')",
                  "    pm.expect(data.goals).to.have.property('byCategory')",
                  "})",
                  "pm.test('Response has milestones stats', () => {",
                  "    const data = pm.response.json().data",
                  "    pm.expect(data).to.have.property('milestones')",
                  "    pm.expect(data.milestones).to.have.property('totalCreated')",
                  "    pm.expect(data.milestones).to.have.property('completed')",
                  "    pm.expect(data.milestones).to.have.property('completionRate')",
                  "    pm.expect(data.milestones).to.have.property('streak')",
                  "    pm.expect(data.milestones).to.have.property('active')",
                  "    pm.expect(data.milestones).to.have.property('paused')",
                  "})"
