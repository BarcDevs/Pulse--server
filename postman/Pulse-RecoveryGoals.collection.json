{
  "info": {
    "name": "pulse - Recovery Goals",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4001"
    },
    {
      "key": "apiVersion",
      "value": "v1"
    },
    {
      "key": "_csrf",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "testEmail",
      "value": ""
    },
    {
      "key": "testPassword",
      "value": ""
    },
    {
      "key": "profileId",
      "value": ""
    },
    {
      "key": "goalId",
      "value": ""
    },
    {
      "key": "milestoneId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"recoverygoals_test_{{$timestamp}}@test.com\", \"password\": \"Test@123456\", \"username\": \"testuser_{{$timestamp}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201))",
                  "const data = pm.response.json().data",
                  "pm.environment.set('testEmail', data.email)",
                  "pm.environment.set('testPassword', 'Test@123456')"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"password\": \"{{testPassword}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200))",
                  "const data = pm.response.json().data",
                  "pm.environment.set('token', data.token)",
                  "pm.environment.set('_csrf', data._csrf)"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Profile (for profileId)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "accessToken={{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "profile"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200))",
                  "const data = pm.response.json().data",
                  "pm.environment.set('profileId', data.id)"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Create Goal",
      "item": [
        {
          "name": "Create Goal - Happy Path",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "accessToken={{token}}"
              },
              {
                "key": "x-csrf-token",
                "value": "{{_csrf}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/goals",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "goals"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Physical Recovery\", \"description\": \"Get back to exercising regularly\", \"category\": \"physical\", \"targetDate\": \"2026-06-30\", \"isPrimary\": true}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201))",
                  "pm.test('Response has correct structure', () => {",
                  "    const data = pm.response.json().data",
                  "    pm.expect(data).to.have.property('id')",
                  "    pm.expect(data).to.have.property('profileId')",
                  "    pm.expect(data).to.have.property('title')",
                  "    pm.expect(data).to.have.property('category')",
                  "    pm.expect(data).to.have.property('status')",
                  "    pm.expect(data).to.have.property('progress')",
                  "})",
                  "const data = pm.response.json().data",
                  "pm.environment.set('goalId', data.id)"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
