{
  "info": {
    "name": "HealEase - Forum",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "apiVersion",
      "value": "v1"
    },
    {
      "key": "csrfToken",
      "value": ""
    },
    {
      "key": "postId",
      "value": ""
    },
    {
      "key": "replyId",
      "value": ""
    },
    {
      "key": "tagId",
      "value": ""
