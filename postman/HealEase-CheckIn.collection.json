{
  "info": {
    "name": "HealEase - Check-In",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "apiVersion",
      "value": "v1"
    },
    {
      "key": "_csrf",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "testEmail",
      "value": ""
    },
    {
      "key": "testPassword",
      "value": ""
    }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
  "item": [
    {
      "name": "Auth Errors",
      "item": [
        {
          "name": "Create Check-In Without Authentication",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/check-in",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "check-in"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"moodScore\": 5, \"painLevel\": 3, \"activities\": [\"walking\"]}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('testEmail', 'alice@example.com')",
                  "pm.environment.set('testPassword', 'password123')"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 401\", () => pm.response.to.have.status(401))"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Check-Ins Without Authentication",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/check-in",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "check-in"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 401\", () => pm.response.to.have.status(401))"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Stats Without Authentication",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/check-in/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "check-in",
                "stats"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 401\", () => pm.response.to.have.status(401))"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Login",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"password\": \"{{testPassword}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200))",
                  "pm.test('Sets token and csrf', () => {",
                  "    const data = pm.response.json().data",
                  "    pm.environment.set('token', data.token)",
                  "    pm.environment.set('_csrf', data._csrf)",
                  "})"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Create Check-In",
      "item": [
        {
          "name": "Create Check-In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "accessToken={{token}}"
              },
              {
                "key": "x-csrf-token",
                "value": "{{_csrf}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/check-in",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "check-in"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"moodScore\": 7, \"painLevel\": 2, \"activities\": [\"walking\", \"meditation\"]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200))"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
