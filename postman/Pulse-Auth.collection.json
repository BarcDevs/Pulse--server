    {
      "name": "Login",
      "item": [
        {
          "name": "Login with Correct Credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"password\": \"{{testPassword}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200))",
                  "pm.test('Returns token', () => {",
                  "    const data = pm.response.json().data",
                  "    pm.expect(data).to.have.property('token')",
                  "    pm.environment.set('token', data.token)",
                  "})",
                  "pm.test('Returns _csrf', () => {",
                  "    const data = pm.response.json().data",
                  "    pm.expect(data).to.have.property('_csrf')",
                  "    pm.environment.set('_csrf', data._csrf)",
                  "})"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Authenticated Tests",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "accessToken={{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200))",
                  "pm.test(\"Returns user data\", () => {",
                  "    const data = pm.response.json().data",
                  "    pm.expect(data).to.have.property(\"user\")",
                  "})"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh CSRF Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "accessToken={{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "auth",
                "refresh"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200))",
                  "pm.test(\"Returns new CSRF token\", () => {",
                  "    const data = pm.response.json().data",
                  "    pm.expect(data).to.have.property(\"_csrf\")",
                  "})"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Logout",
      "item": [
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "accessToken={{token}}"
              }
            ],
