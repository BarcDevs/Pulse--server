{
  "info": {
    "name": "pulse - Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4001"
    },
    {
      "key": "apiVersion",
      "value": "v1"
    },
    {
      "key": "_csrf",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "testEmail",
      "value": "test-{{$timestamp}}@example.com"
    },
    {
      "key": "testPassword",
      "value": "TestPass123!"
    },
    {
      "key": "newPassword",
      "value": "NewPass456@"
    },
    {
      "key": "resetOTP",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "changeEmailOTP",
      "value": ""
    }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
  "item": [
    {
      "name": "Auth Errors",
      "item": [
        {
          "name": "Login with Missing Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "{{apiVersion}}",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"password\": \"TestPass123\"}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('testEmail', 'alice@example.com')",
                  "pm.environment.set('testPassword', 'password123')"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 401\", () => pm.response.to.have.status(401))"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login with Missing Password",
