    {
      "name": "❌ DUPLICATE ERROR TESTS - Run Twice Each",
      "description": "Instructions: Click the test, then click 'Send' twice. First run=201, Second run=409",
      "item": [
        {
          "name": "❌ Test Duplicate Email - RUN TWICE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.test('First run OK - Run this again to test 409', function() {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "  });",
                  "} else if (pm.response.code === 409) {",
                  "  pm.test('Duplicate email returns 409', function() {",
                  "    pm.response.to.have.status(409);",
                  "    pm.expect(pm.response.json().error[0].error).to.equal('User already exists!');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Dup\", \"lastName\": \"Email\", \"email\": \"duplicate-email-test123@example.com\", \"password\": \"Password123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        },
        {
          "name": "❌ Test Duplicate Username - RUN TWICE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.test('First run OK - Run this again to test 409', function() {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "  });",
                  "} else if (pm.response.code === 409) {",
                  "  pm.test('Duplicate username returns 409', function() {",
                  "    pm.response.to.have.status(409);",
                  "    pm.expect(pm.response.json().error[0].error).to.equal('Username already taken!');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Dup\", \"lastName\": \"Username\", \"email\": \"test-dupusername@example.com\", \"username\": \"duplicateusername123\", \"password\": \"Password123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        }
      ]
    },
    {
      "name": "✅ Check-In Tests - Idempotent POST",
      "description": "Check-in POST is idempotent: returns 201 on create, 200 on update. Safe to call multiple times.",
      "item": [
        {
          "name": "✅ Create Check-In - First Time (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Check-in created', function () {",
                  "    pm.response.to.have.status(201);",
                  "    pm.expect(pm.response.json().message).to.include('created');",
                  "});",
                  "pm.test('Response has check-in data', function () {",
                  "    pm.expect(pm.response.json().data.id).to.exist;",
                  "    pm.expect(pm.response.json().data.moodScore).to.equal(7);",
                  "    pm.expect(pm.response.json().data.updatedAt).to.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"moodScore\": 7, \"painLevel\": 3, \"activities\": [\"walking\", \"stretching\"], \"notes\": \"Feeling better today\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/check-in",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "check-in"]
            }
          }
        },
        {
          "name": "✅ Create Check-In Again - Falls Back to Update (200)",
          "description": "Running the same POST again falls back to update. No 409 error.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Check-in updated (not created)', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json().message).to.include('updated');",
                  "});",
                  "pm.test('Response has updated check-in data', function () {",
                  "    pm.expect(pm.response.json().data.id).to.exist;",
                  "    pm.expect(pm.response.json().data.moodScore).to.equal(7);",
                  "    pm.expect(pm.response.json().data.updatedAt).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"moodScore\": 7, \"painLevel\": 3, \"activities\": [\"walking\", \"stretching\"], \"notes\": \"Feeling better today\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/check-in",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "check-in"]
            }
          }
        },
        {
          "name": "✅ Get Check-Ins (Last 30)",
          "description": "Retrieves last 30 check-ins (default limit increased from 10 to 30)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/check-in?limit=30",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "check-in"],
              "query": [{"key": "limit", "value": "30"}]
            }
          }
        },
        {
          "name": "✅ Get Check-In Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/check-in/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "check-in", "stats"]
            }
          }
        }
      ]
    },
