    "dompurify": "^3.0.9",
    "dotenv": "^16.4.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-winston": "^4.2.0",
    "geoip-lite": "^2.0.2",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "9.0.3",
    "morgan": "^1.10.0",
    "ms": "^2.1.3",
    "node-cache": "^5.1.2",
    "nodemailer": "8.0.5",
    "pg": "^8.17.2",
    "prisma": "^7.7.0",
