{
  "name": "pulse-api",
  "version": "0.17.1",
  "description": "",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ],
    "*.js": "eslint --cache --fix"
  },
  "main": "index.js",
  "scripts": {
    "start": "node dist/src/app.js",
    "build": "npx prisma generate && (npx prisma migrate resolve --rolled-back 20260602_migrate_daily_checkin_to_profile || true) && npx prisma migrate deploy && tsc",
    "start:dev": "NODE_ENV=development node --watch --import tsx src/app.ts",
    "start:prod": "NODE_ENV=production node build/index.bundle.js",
    "prod": "npm run prisma:generate && npm run prisma:deploy && webpack",
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit --coverage",
    "test:integration": "NODE_ENV=test jest --config jest.integration.config.ts --detectOpenHandles --forceExit",
    "format": "prettier --write 09",
    "lint:check": "eslint",
    "lint:fix": "npm run lint:check -- --fix",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --name init",
    "prisma:deploy": "npx prisma migrate deploy",
    "prisma:studio": "npx prisma studio",
    "db:dev:migrate": "npx prisma migrate dev",
    "db:dev:reset": "npx prisma migrate reset",
    "typecheck": "tsc --noEmit",
    "postinstall": ""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "1.17.0",
