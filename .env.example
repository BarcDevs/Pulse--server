# ============================================
# HealEase Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# --------------------------------------------
# Environment Configuration
# --------------------------------------------
# Options: development | production | test
NODE_ENV=development

# --------------------------------------------
# Server Configuration
# --------------------------------------------
# Port the server will listen on
PORT=4000

# CORS origin - Frontend URL (comma-separated for multiple origins)
# Development: http://localhost:5173
# Production: https://your-frontend-domain.com
ORIGIN=http://localhost:5173

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
#
# Local PostgreSQL example:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/healease
#
# Neon (Serverless PostgreSQL) example:
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/database?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/healease

# --------------------------------------------
# Authentication Configuration
# --------------------------------------------
# JWT Secret - Generate a strong random string
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-to-a-random-64-char-string

# JWT Token Expiration (optional - defaults handled by config)
# Examples: 1d (1 day), 7d (7 days), 24h (24 hours)
# JWT_EXPIRES_IN=1d

# OTP Expiration for email verification (optional)
# Examples: 5m (5 minutes), 10m (10 minutes)
# OTP_EXPIRATION=10m

# --------------------------------------------
# Email Configuration (for password reset & verification)
# --------------------------------------------
# SMTP Host
# Gmail: smtp.gmail.com
# Outlook: smtp-mail.outlook.com
# Mailtrap (testing): sandbox.smtp.mailtrap.io
EMAIL_HOST=smtp.gmail.com

# Email Service Provider
EMAIL_SERVICE=gmail

# SMTP Port
# Common ports: 587 (TLS), 465 (SSL), 25 (unencrypted)
EMAIL_PORT=587

# Use secure connection (true for SSL, false for TLS)
EMAIL_SECURE=false

# Email account credentials
# For Gmail: Use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# --------------------------------------------
# Optional Environment Variables
# --------------------------------------------
# These are handled by config files and have defaults
# Uncomment and modify if needed

# Server Host (default: localhost for dev, 0.0.0.0 for production)
# SERVER_HOST=localhost

# Server Protocol (default: http for dev, https for production)
# SERVER_PROTOCOL=http

# API Version (default: v1)
# SERVER_API_VERSION=v1

# --------------------------------------------
# Development Tools (Optional)
# --------------------------------------------
# Prisma Studio Port (if using)
# PRISMA_STUDIO_PORT=5555

# --------------------------------------------
# Production-Specific Variables
# --------------------------------------------
# These are typically set by your hosting provider (Render, Heroku, etc.)
# and don't need to be in your local .env

# Render automatically provides PORT
# Render example:
# PORT=10000

# Production frontend URL
# ORIGIN=https://your-production-frontend.com

# --------------------------------------------
# Security Notes
# --------------------------------------------
# 1. NEVER commit .env to git
# 2. Use strong, unique values for JWT_SECRET
# 3. Use app-specific passwords for email (not your main password)
# 4. Rotate secrets regularly in production
# 5. Use environment variables in your hosting platform for production
# 6. Keep this .env.example file up to date but with dummy values
