generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum InsightType {
  DAILY_MOTIVATION
  TREND_ANALYSIS
  ACTIVITY_SUGGESTIONS
}

model User {
  id        String @id() @default(uuid())
  firstName String
  lastName  String
  username  String @unique
  email     String @unique
  googleId  String? @unique
  role      Role   @default(USER)

  profile      Profile?
  posts        Post[]
  replies      Reply[]
  followedTags Tag[]
  checkIns     DailyCheckIn[]

  // excluded from client
  password                String
  resetPasswordOTP        Int?
  resetPasswordExpiration DateTime?
  password_updated_at     DateTime  @default(now())
  created_at              DateTime  @default(now())
  active                  Boolean   @default(true)
  deleted_at              DateTime?
  lastCheckInAt           DateTime?

  @@index([email, created_at, active])
}

model Profile {
  id     String @id() @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  image    String?
  bio      String?
  location String?
  timezone String?

  healthInterests     ProfileHealthInterest[]
  activityPreferences ProfileActivityPreference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model HealthInterest {
  id          String  @id() @default(uuid())
  slug        String  @unique
  name        String
  description String?
  category    String?
  sortOrder   Int?
  isActive    Boolean @default(true)

  profiles ProfileHealthInterest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([category, sortOrder])
}

model ActivityPreference {
  id          String  @id() @default(uuid())
  slug        String  @unique
  name        String
  description String?
  category    String?
  sortOrder   Int?
  isActive    Boolean @default(true)

  profiles ProfileActivityPreference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([category, sortOrder])
}

model ProfileHealthInterest {
  id        String  @id() @default(uuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  healthInterestId String
  healthInterest   HealthInterest @relation(fields: [healthInterestId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@unique([profileId, healthInterestId])
  @@index([profileId])
  @@index([healthInterestId])
}

model ProfileActivityPreference {
  id        String  @id() @default(uuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  activityPreferenceId String
  activityPreference   ActivityPreference @relation(fields: [activityPreferenceId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@unique([profileId, activityPreferenceId])
  @@index([profileId])
  @@index([activityPreferenceId])
}

model Post {
  id        String    @id() @default(uuid())
  title     String
  body      String
  author    User      @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  votes     Json      @default("{\"upvotedBy\": [], \"downvotedBy\": [], \"upvotes\": 0, \"downvotes\": 0}")
  replies   Reply[]
  views     Int       @default(0)
  category  String
  tags      Tag[]
}

model Reply {
  id        String    @id() @default(uuid())
  body      String
  author    User      @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  votes     Json      @default("{\"upvotedBy\": [], \"downvotedBy\": [], \"upvotes\": 0, \"downvotes\": 0}")
  post      Post      @relation(fields: [postId], references: [id])
  postId    String
}

model DailyCheckIn {
  id          String      @id() @default(uuid())
  user        User        @relation(fields: [userId], references: [id])
  userId      String
  checkInDate DateTime    @db.Date
  moodScore   Int
  painLevel   Int
  activities  String[]
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime?
  insights    AIInsight[]

  @@unique([userId, checkInDate])
  @@index([userId, checkInDate])
}

model AIInsight {
  id        String       @id() @default(uuid())
  checkIn   DailyCheckIn @relation(fields: [checkInId], references: [id])
  checkInId String
  type      InsightType
  content   String
  createdAt DateTime     @default(now())
}

model Tag {
  id          String   @id() @default(uuid())
  name        String   @unique
  description String?
  posts       Post[]
  followers   User[]
  createdAt   DateTime @default(now())
}
