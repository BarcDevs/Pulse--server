generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(uuid())
  firstName String
  lastName  String
  username  String  @unique
  email     String  @unique
  role      Role    @default(USER)
  googleId  String? @unique

  createdAt DateTime @default(now())
  active    Boolean  @default(true)

  password                String
  resetPasswordOTP        Int?
  resetPasswordExpiration DateTime?
  passwordUpdatedAt       DateTime  @default(now())
  deletedAt               DateTime?

  pendingEmail          String?
  emailChangeOTP        Int?
  emailChangeExpiration DateTime?

  profile Profile?

  @@index([email, createdAt, active])
}

model Profile {
  id         String   @id @default(uuid())
  userId     String   @unique
  image      String?
  bio        String?
  location   String?
  timezone   String  @default("Asia/Jerusalem")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  dateFormat String?  @default("dd/mm/yyyy")

  anonymousParticipation Boolean   @default(true)
  communityAlerts        Boolean   @default(false)
  dailyReminder          Boolean   @default(true)
  language               String    @default("he-IL")
  profileVisibility      String    @default("friends")
  theme                  String    @default("light")
  lastCheckInAt          DateTime?

  healthInterests     String[] @default([])
  activityPreferences String[] @default([])

  posts         Post[]
  replies       Reply[]
  followedTags  ProfileToTag[]
  checkIns      DailyCheckIn[]
  recoveryGoals RecoveryGoal[]
  postLikes     PostLike[]
  replyLikes          ReplyLike[]
  savedPosts          SavedPost[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Post {
  id        String    @id @default(uuid())
  title     String
  body      String
  authorId  String
  author    Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  views     Int       @default(0)
  category  String
  replies   Reply[]
  tags      Tag[]     @relation("PostToTag")
  likes     PostLike[]
  savedBy   SavedPost[]

  @@index([authorId])
  @@index([category])
}

model Reply {
  id        String    @id @default(uuid())
  body      String
  authorId  String
  author    Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes     ReplyLike[]

  @@index([authorId])
}

model DailyCheckIn {
  id              String              @id @default(uuid())
  profileId       String
  profile         Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  checkInDate     DateTime            @db.Date
  moodScore       Int
  painLevel       Int
  activities      String[]
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?
  insights        AIInsight[]
  recommendations PostRecommendation?

  @@unique([profileId, checkInDate])
  @@index([profileId, checkInDate])
}

model PostRecommendation {
  id                String       @id @default(uuid())
  userId            String
  checkInId         String       @unique
  checkIn           DailyCheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  items             Json // Array<{postId, score, contentType, breakdown}>
  generatedAt       DateTime     @default(now())
  generationPending Boolean      @default(false)
  pendingSince      DateTime?

  @@index([userId])
}

model AIInsight {
  id             String       @id @default(uuid())
  checkInId      String
  type           InsightType
  content        String
  createdAt      DateTime     @default(now())
  title          String
  userId         String
  metadata       Json?
  classification String       @default("baseline")
  priority       String       @default("normal")
  checkIn        DailyCheckIn @relation(fields: [checkInId], references: [id])

  @@unique([checkInId, type])
  @@index([userId, createdAt])
}

model Tag {
  id          String         @id @default(uuid())
  name        String         @unique
  nameHe      String
  description String?
  createdAt   DateTime       @default(now())
  slug        String         @unique
  posts       Post[]         @relation("PostToTag")
  profiles    ProfileToTag[]
}

model ProfileToTag {
  id        String   @id @default(uuid())
  profileId String
  tagId     String
  addedAt   DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([profileId, tagId])
  @@index([profileId])
  @@index([tagId])
}

model UnknownTagAttempt {
  id         String   @id @default(uuid())
  tagName    String   @unique
  count      Int      @default(1)
  lastSeenAt DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([count])
}

model RecoveryGoal {
  id          String       @id @default(cuid())
  profileId   String
  profile     Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String       @db.VarChar(150)
  description String?      @db.Text
  category    GoalCategory
  isPrimary   Boolean      @default(false)
  status      GoalStatus   @default(ACTIVE)
  targetDate  DateTime?    @db.Date
  pausedAt    DateTime?
  completedAt DateTime?
  abandonedAt DateTime?
  milestones  Milestone[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([profileId])
}

model Milestone {
  id          String          @id @default(cuid())
  goalId      String
  goal        RecoveryGoal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title       String          @db.VarChar(150)
  description String?         @db.Text
  order       Int
  status      MilestoneStatus @default(LOCKED)
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([goalId, order])
  @@index([goalId])
}

model PostLike {
  profileId String
  postId    String
  likedAt   DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([profileId, postId])
  @@index([postId])
}

model ReplyLike {
  profileId String
  replyId   String
  likedAt   DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reply     Reply    @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@id([profileId, replyId])
  @@index([replyId])
}

model SavedPost {
  profileId String
  postId    String
  savedAt   DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([profileId, postId])
  @@index([profileId])
}

enum Role {
  USER
  ADMIN
}

enum GoalCategory {
  PHYSICAL
  MENTAL
  LIFESTYLE
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

enum MilestoneStatus {
  LOCKED
  ACTIVE
  COMPLETED
}

enum InsightType {
  MOOD_DROP_ALERT
  MOTIVATIONAL
  WEEKLY_SUMMARY
  BAD_DAY_SUPPORT
}
