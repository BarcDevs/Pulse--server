{
  "info": {
    "name": "HealEase Server - Auth & Signup",
    "description": "Test collection for HealEase authentication endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": []
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup - Valid User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate random values for unique user creation",
                  "const randomSuffix = Math.random().toString(36).substring(2, 10);",
                  "pm.environment.set('randomEmail', `user.${randomSuffix}@example.com`);",
                  "pm.environment.set('randomFirstName', `User${randomSuffix.substring(0, 4)}`);",
                  "pm.environment.set('randomLastName', `Test${randomSuffix.substring(4)}`);",
                  "pm.environment.set('lastCreatedEmail', `user.${randomSuffix}@example.com`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains user data', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.have.property('user');",
                  "});",
                  "",
                  "pm.test('User does not contain password', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.user).to.not.have.property('password');",
                  "});",
                  "",
                  "pm.test('Message is user created!', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.equal('user created!');",
                  "});",
                  "",
                  "pm.test('User has auto-generated username', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.user.username).to.exist;",
                  "    pm.expect(jsonData.data.user.username).to.match(/^user\\d+\\d+$/);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"{{randomFirstName}}\",\n  \"lastName\": \"{{randomLastName}}\",\n  \"email\": \"{{randomEmail}}\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Signup - With Custom Username",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate random values for unique user creation",
                  "const randomSuffix = Math.random().toString(36).substring(2, 10);",
                  "const randomUsername = `user_${randomSuffix}`;",
                  "pm.environment.set('randomEmail2', `user2.${randomSuffix}@example.com`);",
                  "pm.environment.set('randomUsername', randomUsername);",
                  "pm.environment.set('randomFirstName2', `Jane${randomSuffix.substring(0, 3)}`);",
                  "pm.environment.set('randomLastName2', `Smith${randomSuffix.substring(3, 6)}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('User has custom username', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.user.username).to.equal(pm.environment.get('randomUsername'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"{{randomFirstName2}}\",\n  \"lastName\": \"{{randomLastName2}}\",\n  \"email\": \"{{randomEmail2}}\",\n  \"username\": \"{{randomUsername}}\",\n  \"password\": \"Password456!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Signup - Duplicate Email",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Use the email from the first signup test",
                  "const duplicateEmail = pm.environment.get('lastCreatedEmail');",
                  "if (!duplicateEmail) {",
                  "    console.warn('Warning: lastCreatedEmail not set. Run \"Signup - Valid User\" first.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 409 Conflict', function () {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test('Error message indicates user already exists', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error[0].error).to.equal('User already exists!');",
                  "    pm.expect(jsonData.error[0].statusType).to.equal('Conflict');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Another\",\n  \"lastName\": \"Person\",\n  \"email\": \"{{lastCreatedEmail}}\",\n  \"password\": \"DifferentPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "signup"
              ]
            }
          }
        },
