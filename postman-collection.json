        {
          "name": "Signup - Duplicate Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 409 Conflict', function () {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test('Error message indicates user already exists', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error[0].error).to.equal('User already exists!');",
                  "    pm.expect(jsonData.error[0].statusType).to.equal('Conflict');",
