{
  "info": {
    "name": "HealEase Server - Auth & Signup Tests",
    "description": "Complete test suite for signup with success (2xx) using random values and duplicate error tests (409) that must be run twice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": []
  },
  "item": [
    {
      "name": "✅ SUCCESS TESTS - Use Random Values Each Run",
      "description": "All tests generate unique random values - can run anytime without conflicts",
      "item": [
        {
          "name": "✅ Signup - Valid User with Random Email",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "const r = Math.floor(Math.random() * 999999);",
                  "pm.environment.set('randomEmail', `test${ts}${r}@example.com`);",
                  "pm.environment.set('randomName', `User${r}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - User Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has user data', function () {",
                  "    pm.expect(pm.response.json().data.user.username).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"{{randomName}}\", \"lastName\": \"Test\", \"email\": \"{{randomEmail}}\", \"password\": \"Password123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        },
        {
          "name": "✅ Signup - Custom Username (Random)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "const r = Math.floor(Math.random() * 999999);",
                  "pm.environment.set('randomEmail2', `test2${ts}${r}@example.com`);",
                  "pm.environment.set('randomUsername', `user${r}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - User with custom username created', function () {",
                  "    pm.response.to.have.status(201);",
                  "    pm.expect(pm.response.json().data.user.username).to.equal(pm.environment.get('randomUsername'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Jane\", \"lastName\": \"Test\", \"email\": \"{{randomEmail2}}\", \"username\": \"{{randomUsername}}\", \"password\": \"Password456!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        },
        {
          "name": "✅ Validation - Missing Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 - Validation Error', function () {",
                  "    pm.response.to.have.status(403);",
                  "    pm.expect(pm.response.json().error[0].property).to.equal('email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"John\", \"lastName\": \"Doe\", \"password\": \"Password123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        },
        {
          "name": "✅ Validation - Invalid Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 - Invalid email format', function () {",
                  "    pm.response.to.have.status(403);",
                  "    pm.expect(pm.response.json().error[0].property).to.equal('email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"invalid\", \"password\": \"Password123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        },
        {
          "name": "✅ Validation - Weak Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 - Weak password', function () {",
                  "    pm.response.to.have.status(403);",
                  "    pm.expect(pm.response.json().error[0].property).to.equal('password');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"test@example.com\", \"password\": \"weak\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        }
      ]
    },
    {
      "name": "❌ DUPLICATE ERROR TESTS - Run Twice Each",
      "description": "Instructions: Click the test, then click 'Send' twice. First run=201, Second run=409",
      "item": [
        {
          "name": "❌ Test Duplicate Email - RUN TWICE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.test('First run OK - Run this again to test 409', function() {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "  });",
                  "} else if (pm.response.code === 409) {",
                  "  pm.test('Duplicate email returns 409', function() {",
                  "    pm.response.to.have.status(409);",
                  "    pm.expect(pm.response.json().error[0].error).to.equal('User already exists!');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Dup\", \"lastName\": \"Email\", \"email\": \"duplicate-email-test123@example.com\", \"password\": \"Password123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        },
        {
          "name": "❌ Test Duplicate Username - RUN TWICE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.test('First run OK - Run this again to test 409', function() {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "  });",
                  "} else if (pm.response.code === 409) {",
                  "  pm.test('Duplicate username returns 409', function() {",
                  "    pm.response.to.have.status(409);",
                  "    pm.expect(pm.response.json().error[0].error).to.equal('Username already taken!');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Dup\", \"lastName\": \"Username\", \"email\": \"test-dupusername@example.com\", \"username\": \"duplicateusername123\", \"password\": \"Password123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        }
      ]
    },
    {
      "name": "Other Endpoints",
      "item": [
